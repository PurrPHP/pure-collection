{
  "name": "purrphp/pure-collection",
  "type": "library",
  "description": "Immutable type-safe collections for PHP",
  "license": "MIT",
  "keywords": ["php", "collection", "immutable", "type-safe", "data-structures", "list", "map", "set"],
  "authors": [
    {
      "name": "Purr",
      "homepage": "https://github.com/purrphp"
    }
  ],
  "homepage": "https://github.com/purrphp/collection",
  "support": {
    "issues": "https://github.com/purrphp/collection/issues",
    "source": "https://github.com/purrphp/collection"
  },
  "autoload": {
    "psr-4": {
      "Purr\\Collection\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Purr\\Collection\\Test\\": "test/unit"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "coverage": "vendor/bin/phpunit --coverage-text --colors=never --coverage-clover coverage/clover.xml",
    "cs-fix": "vendor/bin/php-cs-fixer fix",
    "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
    "refactor": "vendor/bin/rector process",
    "check": [
      "@cs-check",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "platform": {
      "php": "8.1.0"
    },
    "process-timeout": 0,
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true
    }
  }
}
