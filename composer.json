{
  "name": "purr/collection",
  "type": "library",
  "description": "Immutable type-safe collection data structures for PHP",
  "license": "MIT",
  "keywords": ["php", "collection", "immutable", "type-safe", "data-structures", "list", "map", "set"],
  "authors": [
    {
      "name": "Purr",
      "homepage": "https://github.com/purrphp"
    }
  ],
  "homepage": "https://github.com/purrphp/collection",
  "support": {
    "issues": "https://github.com/purrphp/collection/issues",
    "source": "https://github.com/purrphp/collection"
  },
  "autoload": {
    "psr-4": {
      "Purr\\Collection\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Purr\\Collection\\Tests\\": "tests/"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.0",
    "rector/rector": "^0.18"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "cs-fix": "vendor/bin/php-cs-fixer fix",
    "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "analyse": "vendor/bin/phpstan analyse",
    "refactor": "vendor/bin/rector process",
    "check": [
      "@cs-check",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    },
    "process-timeout": 0,
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true
    }
  }
}
